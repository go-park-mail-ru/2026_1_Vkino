AUTH_JWT_SECRET=change-me

MINIO_ROOT_USER=your_minio_name
MINIO_ROOT_PASSWORD=your_minio_pass

# -----------------------------------------------------------------------------
# PostgreSQL bootstrap/admin users
# POSTGRES_ADMIN_USER / POSTGRES_ADMIN_PASSWORD используются bootstrap/grants
# скриптами для административного подключения к БД.
# -----------------------------------------------------------------------------

POSTGRES_ADMIN_USER=vkino_user
POSTGRES_ADMIN_PASSWORD=vkino
POSTGRES_DB=vkino

# -----------------------------------------------------------------------------
# PostgreSQL service accounts
# -----------------------------------------------------------------------------

VKINO_AUTH_DB_USER=vkino_auth_service
VKINO_AUTH_DB_PASSWORD=vkino_auth_password

VKINO_USER_DB_USER=vkino_user_service
VKINO_USER_DB_PASSWORD=vkino_user_password

VKINO_MOVIE_DB_USER=vkino_movie_service
VKINO_MOVIE_DB_PASSWORD=vkino_movie_password

VKINO_MIGRATOR_DB_USER=vkino_migrator
VKINO_MIGRATOR_DB_PASSWORD=vkino_migrator_password

VKINO_MONITORING_DB_USER=vkino_monitoring
VKINO_MONITORING_DB_PASSWORD=vkino_monitoring_password

# Development-only Grafana credentials.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
