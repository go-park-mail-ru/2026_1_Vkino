AUTH_JWT_SECRET=change-me

MINIO_ROOT_USER=your_minio_name
MINIO_ROOT_PASSWORD=your_minio_pass

GRAFANA_ADMIN_USER=change_me
GRAFANA_ADMIN_PASSWORD=change_me_strong_password

# -----------------------------------------------------------------------------
# PostgreSQL admin/bootstrap account
# Используется только для инициализации контейнера и административных скриптов.
# Runtime-приложение под ним работать не должно.
# -----------------------------------------------------------------------------

POSTGRES_ADMIN_USER=your_postgres_admin_user
POSTGRES_ADMIN_PASSWORD=your_postgres_admin_pass
POSTGRES_DB=your_postgres_db


# -----------------------------------------------------------------------------
# PostgreSQL service accounts
# -----------------------------------------------------------------------------

VKINO_AUTH_DB_USER=vkino_auth_service
VKINO_AUTH_DB_PASSWORD=change_me_auth_password

VKINO_USER_DB_USER=vkino_user_service
VKINO_USER_DB_PASSWORD=change_me_user_password

VKINO_MOVIE_DB_USER=vkino_movie_service
VKINO_MOVIE_DB_PASSWORD=change_me_movie_password

VKINO_MIGRATOR_DB_USER=vkino_migrator
VKINO_MIGRATOR_DB_PASSWORD=change_me_migrator_password

VKINO_MONITORING_DB_USER=vkino_monitoring
VKINO_MONITORING_DB_PASSWORD=change_me_monitoring_password
